{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Httply",
  "version": "0.1.0",
  "identifier": "io.qzz.httply",
  "build": {
    "frontendDist": "https://app.httply.qzz.io/",
    "devUrl": "https://app.httply.qzz.io/",
    "beforeDevCommand": "",
    "beforeBuildCommand": ""
  },
  "app": {
    "windows": [
      {
        "title": "Httply",
        "width": 800,
        "height": 600,
        "resizable": true,
        "fullscreen": false,
        "maximized": true,
        "transparent": true,
        "theme": "Dark"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "android": {
      "debugApplicationIdSuffix": ".debug"
    }
  }
}
